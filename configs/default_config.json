{
  "$schema": "../schema/config_schema.json",
  "fields": [
    { "path": "candidate_id", "type": "string", "required": true },
    { "path": "full_name", "type": "string", "required": true, "normalize": "titlecase" },
    { "path": "emails", "type": "array", "normalize": "lowercase" },
    { "path": "phones", "type": "array", "normalize": "E164" },
    { "path": "location", "type": "object" },
    { "path": "location.city", "type": "string", "normalize": "titlecase" },
    { "path": "location.region", "type": "string", "normalize": "titlecase" },
    { "path": "location.country", "type": "string", "normalize": "uppercase" },
    { "path": "links", "type": "object" },
    { "path": "links.linkedin", "type": "string" },
    { "path": "links.github", "type": "string" },
    { "path": "links.portfolio", "type": "string" },
    { "path": "links.other", "type": "array" },
    { "path": "headline", "type": "string" },
    { "path": "years_experience", "type": "number" },
    { "path": "skills", "type": "array" },
    { "path": "skills[].name", "type": "string", "normalize": "canonical" },
    { "path": "skills[].confidence", "type": "number" },
    { "path": "skills[].sources", "type": "array" },
    { "path": "experience", "type": "array" },
    { "path": "experience[].company", "type": "string" },
    { "path": "experience[].title", "type": "string" },
    { "path": "experience[].start", "type": "string", "normalize": "iso_date" },
    { "path": "experience[].end", "type": "string", "normalize": "iso_date" },
    { "path": "experience[].summary", "type": "string" },
    { "path": "education", "type": "array" },
    { "path": "education[].institution", "type": "string" },
    { "path": "education[].degree", "type": "string" },
    { "path": "education[].field", "type": "string" },
    { "path": "education[].end_year", "type": "number" },
    { "path": "provenance", "type": "array" },
    { "path": "provenance[].field", "type": "string" },
    { "path": "provenance[].source", "type": "string" },
    { "path": "provenance[].method", "type": "string" },
    { "path": "overall_confidence", "type": "number" }
  ],
  "include_confidence": true,
  "on_missing": "null"
}
